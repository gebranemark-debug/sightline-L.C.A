DATABASE_URL=sqlite:///./sightline.db
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model routing per input type.
# Text pipeline (JSON body → /api/analyze): defaults to opus if unset.
ANTHROPIC_MODEL_TEXT=claude-opus-4-7
# PDF pipeline (multipart → /api/analyze): defaults to Sonnet 5 (released
# 2026-06-30 with launch pricing $2/$10 through 2026-08-31 — meaningfully
# better than Sonnet 4.5 for structured extraction at this scale). PDF page
# tokens run ~30x higher per analysis so the cheaper capable model is the
# right default here.
ANTHROPIC_MODEL_PDF=claude-sonnet-5

# Legacy: if set, still honored as a fallback for the text pipeline when
# ANTHROPIC_MODEL_TEXT is not set. New setups should use the two vars above.
# ANTHROPIC_MODEL=claude-opus-4-8

CORS_ORIGINS=http://localhost:5173
