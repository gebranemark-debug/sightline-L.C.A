# Copy this file to .env (which is gitignored) and adjust as needed.
#
# VITE_API_BASE is the backend origin the frontend calls (`${VITE_API_BASE}/api/analyze`).
# Default: the deployed Railway instance — works out of the box for anyone with
# CORS access. Switch to http://localhost:8000 when running the backend locally.

VITE_API_BASE=https://sightline-lca-production.up.railway.app
